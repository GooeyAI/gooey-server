{
  // Type-check only (wrangler bundles with esbuild): npx tsc
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    // Keep .js out of the program so `import EXECUTOR_SOURCE from "./executor.js"`
    // uses the generated `declare module "*.js"` (Text module -> string)
    // instead of resolving to the real executor.js module.
    "allowJs": false,
    // Runtime + Env types generated by `npx wrangler types`; rerun that
    // after changing wrangler.jsonc.
    "types": ["./worker-configuration.d.ts"]
  },
  "include": ["src/**/*.ts", "worker-configuration.d.ts"]
}
